<Window x:Class="Tema1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:Tema1"
        mc:Ignorable="d"
        Title="Tema 1 - Notepad++" Height="600" Width="900">
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewFileCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenFileCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveFileCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+S" Command="{Binding SaveFileAsCommand}"/>
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseFileCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+W" Command="{Binding CloseAllFilesCommand}"/>
        <KeyBinding Gesture="Alt+F4" Command="{Binding ExitCommand}"/>
    </Window.InputBindings>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="New file" InputGestureText="Ctrl+N" Command="{Binding NewFileCommand}"/>
                <MenuItem Header="Open file..." InputGestureText="Ctrl+O" Command="{Binding OpenFileCommand}"/>
                <MenuItem Header="Save file" InputGestureText="Ctrl+S" Command="{Binding SaveFileCommand}"/>
                <MenuItem Header="Save file as..." InputGestureText="Ctrl+Alt+S" Command="{Binding SaveFileAsCommand}"/>
                <MenuItem Header="Close file" InputGestureText="Ctrl+W" Command="{Binding CloseFileCommand}"
                          CommandParameter="{Binding}"/>
                <MenuItem Header="Close all files" InputGestureText="Ctrl+Shift+W" Command="{Binding CloseAllFilesCommand}"/>
                <MenuItem Header="Exit" InputGestureText="Alt+F4" Command="{Binding ExitCommand}"/>
            </MenuItem>

            <MenuItem Header="Search">
                <MenuItem Header="Find..." Click="FindMenuItem_Click"/>
                <MenuItem Header="Replace..." Click="ReplaceMenuItem_Click"/>
            </MenuItem>

            <MenuItem Header="View">
                <MenuItem Header="Standard" Command="{Binding ViewStandardCommand}"/>
                <MenuItem Header="Folder Explorer" Command="{Binding ViewFolderExplorerCommand}"/>
            </MenuItem>

            <MenuItem Header="Help">
                <MenuItem Header="About" Command="{Binding HelpAboutCommand}"/>
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <Button ToolTip="New file" Command="{Binding NewFileCommand}">
                <iconPacks:PackIconMaterial Kind="FilePlus" Foreground="#4CAF50" Width="16" Height="16"/>
            </Button>
            <Button ToolTip="Open file" Command="{Binding OpenFileCommand}">
                <iconPacks:PackIconMaterial Kind="FolderOpen" Foreground="#FF9800" Width="16" Height="16"/>
            </Button>
            <Button ToolTip="Save file" Command="{Binding SaveFileCommand}">
                <iconPacks:PackIconMaterial Kind="ContentSave" Foreground="#2196F3" Width="16" Height="16"/>
            </Button>
            <Separator/>
            
            <Button ToolTip="Close file" Command="{Binding CloseFileCommand}">
                <iconPacks:PackIconMaterial Kind="Close" Foreground="#D32F2F" Width="16" Height="16"/>
            </Button>
            <Button ToolTip="Close all files" Command="{Binding CloseAllFilesCommand}">
                <iconPacks:PackIconMaterial Kind="CloseCircleMultiple" Foreground="#D32F2F" Width="16" Height="16"/>
            </Button>
            
            <Separator/>
            
            <Button ToolTip="Find" Click="FindMenuItem_Click">
                <iconPacks:PackIconMaterial Kind="Magnify" Foreground="#9C27B0" Width="16" Height="16"/>
            </Button>
            <Button ToolTip="Replace" Click="ReplaceMenuItem_Click">
                <iconPacks:PackIconMaterial Kind="FindReplace"  Foreground="#9C27B0" Width="16" Height="16"/>
            </Button>
            
            <Separator/>

            <Button ToolTip="View Standard" Command="{Binding ViewStandardCommand}">
                <iconPacks:PackIconMaterial Kind="ViewCompact" Foreground="#607D8B" Width="16" Height="16"/>
            </Button>
            <Button ToolTip="Folder Explorer" Command="{Binding ViewFolderExplorerCommand}">
                <iconPacks:PackIconMaterial Kind="FolderEye" Foreground="#607D8B" Width="16" Height="16"/>
            </Button>
            <Separator/>

            <Button ToolTip="About" Command="{Binding HelpAboutCommand}">
                <iconPacks:PackIconMaterial Kind="InformationOutline" Foreground="#00BCD4" Width="16" Height="16"/>
            </Button>

        </ToolBar>

        <DockPanel>
            <TreeView DockPanel.Dock="Left"
              Width="200"
              x:Name="FolderExplorer"
              MouseDoubleClick="TreeView_MouseDoubleClick"
              Visibility="{Binding IsFolderExplorerVisible, Converter={StaticResource BoolToVis}}"
              ItemsSource="{Binding Partitions}">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.ItemContainerStyle>

                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="New file" 
                                  Command="{Binding PlacementTarget.DataContext.NewFileInDirectoryCommand, 
                                           RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Copy path"
                                   Command="{Binding PlacementTarget.DataContext.CopyPathCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                   CommandParameter="{Binding PlacementTarget.SelectedItem,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Copy folder"
                                  Command="{Binding PlacementTarget.DataContext.CopyDirectoryCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        <MenuItem Header="Paste folder"
                                  Command="{Binding PlacementTarget.DataContext.PasteDirectoryCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.SelectedItem,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                    </ContextMenu>
                </TreeView.ContextMenu>

                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Items}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="Icon" Text="📄" Margin="0 0 4 0"/>
                            <TextBlock Text="{Binding Name}"/>
                        </StackPanel>
                        <HierarchicalDataTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                <Setter TargetName="Icon" Property="Text" Value="📁"/>
                            </DataTrigger>
                        </HierarchicalDataTemplate.Triggers>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <DockPanel>
                <TabControl x:Name="MainTabControl"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab, Mode=TwoWay}">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                <Button
                                    Margin="5 0 0 0"
                                    Background="Transparent" BorderBrush="Transparent"
                                    HorizontalAlignment="Left"
                                    Command="{Binding DataContext.CloseFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                    <iconPacks:PackIconMaterial Kind="Close" Foreground="#DD666E" Width="10" Height="10"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </DockPanel>
        </DockPanel>
    </DockPanel>
</Window>
